# ClawTrade Environment Variables
# Copy to .env and fill in real values for production

# Stripe (REQUIRED for real payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server addresses (Fly.io uses 0.0.0.0, local uses 127.0.0.1)
CLAWTRADE_API_ADDR=0.0.0.0:8080
CLAWTRADE_DASHBOARD_ADDR=0.0.0.0:8080

# Local LLM fleet (llama-swap)
LLM_LOCAL_URL=http://127.0.0.1:8080
LLM_LOCAL_MODEL=qwen3.5-9b-131k

# Model overrides (optional — defaults to generic names)
# CLAWTRADE_MODEL_QWEN9B_131K=qwen3.5-9b-131k
# CLAWTRADE_MODEL_QWEN9B_262K=qwen3.5-9b-262k
# CLAWTRADE_MODEL_QWEN9B_524K=qwen3.5-9b-524k
# CLAWTRADE_MODEL_GEMMA12B_131K=gemma-4-12b-131k
# CLAWTRADE_MODEL_GEMMA12B_262K=gemma-4-12b-262k
# CLAWTRADE_MODEL_GEMMA12B_524K=gemma-4-12b-524k
# CLAWTRADE_MODEL_QWEN35B_131K=qwen3.6-35b-131k
# CLAWTRADE_MODEL_QWEN35B_262K=qwen3.6-35b-262k
# CLAWTRADE_MODEL_QWEN35B_524K=qwen3.6-35b-524k
# CLAWTRADE_MODEL_QWEN35BKIMI_131K=qwen3.6-35b-kimi-131k
# CLAWTRADE_MODEL_QWEN35BKIMI_262K=qwen3.6-35b-kimi-262k
# CLAWTRADE_MODEL_QWEN35BKIMI_524K=qwen3.6-35b-kimi-524k

# Database (SQLite — file path)
DATABASE_URL=sqlite://clawtrade.db

# Optional: OpenAI fallback (if local LLM is down)
# OPENAI_API_KEY=sk-...
