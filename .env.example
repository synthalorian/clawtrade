# ClawTrade Environment Variables
# Copy to .env and fill in real values for production

# Stripe (REQUIRED for real payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server addresses (Fly.io uses 0.0.0.0, local uses 127.0.0.1)
CLAWTRADE_API_ADDR=0.0.0.0:8080
CLAWTRADE_DASHBOARD_ADDR=0.0.0.0:8080

# Local LLM fleet (llama-swap)
LLM_LOCAL_URL=http://127.0.0.1:8080
LLM_LOCAL_MODEL=qwen3.5-9b-131k

# Model overrides (optional — defaults to generic names)
# CLAWTRADE_MODEL_QWEN9B=qwen3.5-9b-131k
# CLAWTRADE_MODEL_GEMMA12B=gemma-4-12b-131k
# CLAWTRADE_MODEL_QWEN35B=qwen3.6-35b-131k
# CLAWTRADE_MODEL_PHI4=phi-4-reasoning-plus-262k
# CLAWTRADE_MODEL_GEMMA26B=gemma-4-26b-262k
# CLAWTRADE_MODEL_GEMMA26B_512K=gemma-4-26b-524k

# Database (SQLite — file path)
DATABASE_URL=sqlite://clawtrade.db

# Optional: OpenAI fallback (if local LLM is down)
# OPENAI_API_KEY=sk-...
